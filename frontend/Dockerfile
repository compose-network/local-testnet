# Build stage
FROM node:20-alpine AS builder

WORKDIR /app

COPY package.json package-lock.json ./
RUN npm ci

COPY . .

# Build args for Vite env (injected at build time)
ARG VITE_CHAIN_A_ID=77777
ARG VITE_CHAIN_B_ID=88888
ARG VITE_FLASHBLOCKS_ENABLED=true
ARG VITE_CHAIN_A_BUILDER_RPC=http://localhost:17545
ARG VITE_CHAIN_A_GETH_RPC=http://localhost:18545
ARG VITE_CHAIN_B_BUILDER_RPC=http://localhost:27545
ARG VITE_CHAIN_B_GETH_RPC=http://localhost:28545
ARG VITE_SIDECAR_A_URL=http://localhost:17090
ARG VITE_SIDECAR_B_URL=http://localhost:27090
ARG VITE_CHAIN_A_BRIDGE_ADDRESS
ARG VITE_CHAIN_B_BRIDGE_ADDRESS
ARG VITE_CHAIN_A_TOKEN_ADDRESS
ARG VITE_CHAIN_B_TOKEN_ADDRESS
ARG VITE_WALLET_PRIVATE_KEY

ENV VITE_CHAIN_A_ID=$VITE_CHAIN_A_ID
ENV VITE_CHAIN_B_ID=$VITE_CHAIN_B_ID
ENV VITE_FLASHBLOCKS_ENABLED=$VITE_FLASHBLOCKS_ENABLED
ENV VITE_CHAIN_A_BUILDER_RPC=$VITE_CHAIN_A_BUILDER_RPC
ENV VITE_CHAIN_A_GETH_RPC=$VITE_CHAIN_A_GETH_RPC
ENV VITE_CHAIN_B_BUILDER_RPC=$VITE_CHAIN_B_BUILDER_RPC
ENV VITE_CHAIN_B_GETH_RPC=$VITE_CHAIN_B_GETH_RPC
ENV VITE_SIDECAR_A_URL=$VITE_SIDECAR_A_URL
ENV VITE_SIDECAR_B_URL=$VITE_SIDECAR_B_URL
ENV VITE_CHAIN_A_BRIDGE_ADDRESS=$VITE_CHAIN_A_BRIDGE_ADDRESS
ENV VITE_CHAIN_B_BRIDGE_ADDRESS=$VITE_CHAIN_B_BRIDGE_ADDRESS
ENV VITE_CHAIN_A_TOKEN_ADDRESS=$VITE_CHAIN_A_TOKEN_ADDRESS
ENV VITE_CHAIN_B_TOKEN_ADDRESS=$VITE_CHAIN_B_TOKEN_ADDRESS
ENV VITE_WALLET_PRIVATE_KEY=$VITE_WALLET_PRIVATE_KEY

RUN npm run build

# Serve stage
FROM nginx:alpine

COPY --from=builder /app/dist /usr/share/nginx/html
COPY nginx.conf /etc/nginx/conf.d/default.conf

EXPOSE 3000

CMD ["nginx", "-g", "daemon off;"]
